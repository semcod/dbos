# Copy to .env and customize
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
POSTGRES_PORT=5432

API_PORT=3000
BUS_PORT=4000
UI_PORT=5173
CDN_PORT=8080
WEBDAV_PORT=8090

# FUSE mount (Linux host with /dev/fuse). Use `docker compose --profile fuse up`.
VFS_HOST_MOUNT=./vfs-mount
WEBDAV_USER=admin
WEBDAV_PASS=admin

JWT_SECRET=devsecret-change-me

# sync-engine behaviour
SYNC_MODE=dev          # dev = bi-directional, prod = DB is read-only authority
MERGE_POLICY=lww       # lww (last-write-wins) | db-wins | fs-wins

# --- Protocol gateways (docker compose --profile protocols up) ---
FTP_PORT=2121
FTP_USER=admin
FTP_PASS=admin

IMAP_PORT=1143
IMAP_USER=admin
IMAP_PASS=admin

POP3_PORT=1110
POP3_USER=admin
POP3_PASS=admin

SMTP_PORT=2525

# --- Storage mirroring (docker compose --profile mirrors up) ---
# Declared per-backend in `storage_backends`; these are fallback envs for the
# sqlite/mysql adapters when DSN uses ${VAR} substitution.
# MYSQL_DSN=mysql://user:pass@host:3306/platform

